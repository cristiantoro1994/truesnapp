# =====================================================================
# Archivos y carpetas que Git debe IGNORAR (no subir al repositorio)
# =====================================================================

# --- Entorno virtual de Python ---
venv/
env/
.venv/

# --- Archivos compilados de Python ---
__pycache__/
*.pyc
*.pyo
*.pyd

# --- Configuración de Streamlit ---
.streamlit/secrets.toml

# --- Base de datos local (datos de prueba, no compartir) ---
datos/*.db
datos/*.db-journal

# --- Imágenes subidas por usuarios (no compartir en el repositorio) ---
datos/imagenes/

# --- Editor / IDE ---
.vscode/
.idea/
*.swp
*.swo

# --- Sistema operativo ---
.DS_Store
Thumbs.db

# --- Variables de entorno con claves privadas ---
.env
*.env
